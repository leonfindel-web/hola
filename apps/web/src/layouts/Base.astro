---
import '../styles/global.css';
import { buildMeta, type MetaInput } from '../lib/seo';
import { t, localizedPath, DEFAULT_LANG, type Lang } from '../lib/i18n';

interface Props extends MetaInput {
  jsonLd?: object | null;
  lang?: Lang;
  /** Path WITHOUT language prefix, used to build the language-toggle href. */
  altPath?: string;
}

const {
  jsonLd = null,
  lang = DEFAULT_LANG,
  altPath = '/',
  ...metaInput
} = Astro.props;

const meta = buildMeta({ path: Astro.url.pathname, ...metaInput });
const dict = t(lang);
const otherLang: Lang = lang === 'en' ? 'es' : 'en';
const togglePath = localizedPath(otherLang, altPath);
const htmlLang = lang === 'es' ? 'es' : 'en';
const ogLocale = lang === 'es' ? 'es_CL' : 'en';

const nav = [
  { href: localizedPath(lang, '/work'), label: dict.nav.work },
  { href: localizedPath(lang, '/about'), label: dict.nav.about },
  { href: localizedPath(lang, '/contact'), label: dict.nav.contact },
];
const homeHref = localizedPath(lang, '/');
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:url" content={meta.url} />
    {meta.image && <meta property="og:image" content={meta.image} />}
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    {meta.image && <meta name="twitter:image" content={meta.image} />}

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href={homeHref} class="brand" aria-label="Leonfindel">
          Leonfindel<span class="brand__mark" aria-hidden="true">·archivo</span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="siteNav" aria-label="Abrir menú">
          <span></span><span></span><span></span>
        </button>
        <nav aria-label="Principal" id="siteNav">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
          <a class="lang-toggle" href={togglePath} hreflang={otherLang} rel="alternate">
            {dict.meta.switchTo}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span class="muted">© {new Date().getFullYear()} Leonfindel</span>
        <span class="faint">{dict.footer.tagline}</span>
      </div>
    </footer>

    <script>
      const navToggle = document.getElementById('navToggle');
      const siteNav = document.getElementById('siteNav');
      if (navToggle && siteNav) {
        navToggle.addEventListener('click', () => {
          const isOpen = siteNav.classList.toggle('is-open');
          navToggle.setAttribute('aria-expanded', String(isOpen));
        });
        siteNav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            siteNav.classList.remove('is-open');
            navToggle.setAttribute('aria-expanded', 'false');
          });
        });
      }
    </script>

    <style>
      .site-header {
        border-bottom: 1px solid var(--color-border);
        padding-block: 1rem;
        position: sticky;
        top: 0;
        background: var(--color-bg-overlay);
        backdrop-filter: saturate(160%) blur(10px);
        z-index: 20;
      }
      .site-header__inner {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
      }
      .brand {
        font-weight: 700;
        letter-spacing: var(--tracking-tight);
        font-size: 1.125rem;
      }
      .brand__mark {
        font-family: var(--font-mono);
        font-weight: 400;
        font-size: 0.7rem;
        letter-spacing: var(--tracking-code);
        color: var(--color-fg-faint);
        margin-left: 0.45rem;
      }
      nav {
        display: flex;
        gap: 1.25rem;
        font-size: 0.9rem;
        align-items: baseline;
      }
      nav a {
        color: var(--color-fg-muted);
        transition: color var(--dur-fast) var(--ease);
      }
      nav a:hover {
        color: var(--color-fg);
      }
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 2.25rem;
        height: 2.25rem;
        padding: 0;
        border: none;
        background: none;
        cursor: pointer;
      }
      .nav-toggle span {
        display: block;
        width: 100%;
        height: 1.5px;
        background: var(--color-fg);
        transition: transform var(--dur-fast) var(--ease), opacity var(--dur-fast) var(--ease);
      }
      @media (max-width: 640px) {
        .nav-toggle {
          display: flex;
        }
        nav {
          position: fixed;
          top: 3.6rem;
          right: 1rem;
          left: 1rem;
          flex-direction: column;
          align-items: flex-start;
          gap: 0;
          background: var(--color-bg-elev);
          border: 1px solid var(--color-border);
          border-radius: var(--radius-lg);
          padding: 0.5rem;
          opacity: 0;
          visibility: hidden;
          transform: translateY(-8px);
          transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease), visibility var(--dur) var(--ease);
        }
        nav.is-open {
          opacity: 1;
          visibility: visible;
          transform: translateY(0);
        }
        nav a {
          width: 100%;
          padding: 0.75rem 0.5rem;
          border-bottom: 1px solid var(--color-border);
        }
        nav a:last-child {
          border-bottom: none;
        }
        .lang-toggle {
          border: none !important;
        }
      }
      .lang-toggle {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: var(--tracking-code);
        padding-inline: 0.55rem;
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        line-height: 1.7;
      }
      .lang-toggle:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
      }
      main {
        min-height: calc(100dvh - 200px);
      }
      .site-footer {
        border-top: 1px solid var(--color-border);
        padding-block: 1.25rem;
        margin-top: 5rem;
        font-size: 0.85rem;
      }
      .site-footer__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
    </style>
  </body>
</html>
