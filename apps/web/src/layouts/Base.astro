---
import '../styles/global.css';
import { buildMeta, type MetaInput } from '../lib/seo';

interface Props extends MetaInput {
  jsonLd?: object | null;
}

const { jsonLd = null, ...metaInput } = Astro.props;
const meta = buildMeta({ path: Astro.url.pathname, ...metaInput });
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:url" content={meta.url} />
    {meta.image && <meta property="og:image" content={meta.image} />}
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    {meta.image && <meta name="twitter:image" content={meta.image} />}

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="brand" aria-label="Leonfindel — inicio">Leonfindel</a>
        <nav aria-label="Principal">
          <a href="/work">Trabajo</a>
          <a href="/about">Sobre</a>
          <a href="/contact">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <span class="muted">© {new Date().getFullYear()} Leonfindel</span>
        <span class="faint">Productora audiovisual chilena</span>
      </div>
    </footer>

    <style>
      .site-header {
        border-bottom: 1px solid var(--border);
        padding-block: 1rem;
        position: sticky;
        top: 0;
        background: rgba(14, 14, 14, 0.85);
        backdrop-filter: saturate(180%) blur(8px);
        z-index: 10;
      }
      .site-header__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .brand {
        font-weight: 700;
        letter-spacing: -0.01em;
        font-size: 1.125rem;
      }
      nav {
        display: flex;
        gap: 1.25rem;
        font-size: 0.95rem;
      }
      main {
        min-height: calc(100dvh - 200px);
        padding-block: 2.5rem;
      }
      .site-footer {
        border-top: 1px solid var(--border);
        padding-block: 1.25rem;
        margin-top: 4rem;
        font-size: 0.875rem;
      }
      .site-footer__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
    </style>
  </body>
</html>
