---
import Base from '../../layouts/Base.astro';
import ContactBody from '../../components/pages/ContactBody.astro';
import { t } from '../../lib/i18n';

const lang = 'es' as const;
const dict = t(lang);
---

<Base lang={lang} altPath="/contact" title={dict.contact.title} description={dict.contact.body}>
  <ContactBody lang={lang} />
</Base>
