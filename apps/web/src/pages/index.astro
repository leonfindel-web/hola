---
import Base from '../layouts/Base.astro';
import HomeBody from '../components/pages/HomeBody.astro';
import { t } from '../lib/i18n';

const lang = 'en' as const;
const dict = t(lang);
---

<Base lang={lang} altPath="/" title={dict.home.h1} description={dict.home.sub}>
  <HomeBody lang={lang} />
</Base>
