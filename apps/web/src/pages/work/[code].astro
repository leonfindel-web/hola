---
import Base from '../../layouts/Base.astro';
import { getItem, listAllCodes } from '../../lib/catalog';
import { structuredDataForItem } from '../../lib/seo';
import type { MediaItem } from '@shared/types';

export async function getStaticPaths() {
  // Pre-render one HTML per item code. The list comes from the SEARCH worker
  // at build time. Empty list during initial scaffolding (Worker not deployed
  // yet) — falls through gracefully.
  try {
    const codes = await listAllCodes();
    const items = await Promise.all(
      codes.map(async (code) => {
        const item = await getItem(code);
        return item ? { params: { code }, props: { item } } : null;
      }),
    );
    return items.filter((x): x is { params: { code: string }; props: { item: MediaItem } } => x !== null);
  } catch (e) {
    console.warn('[work/[code]] could not pre-render — search worker unreachable:', (e as Error).message);
    return [];
  }
}

interface Props {
  item: MediaItem;
}

const { item } = Astro.props;
const subtitle = [item.client, item.project, item.year].filter(Boolean).join(' · ');
const tags = item.tags ?? [];
---

<Base
  title={item.title}
  description={item.description ?? `${item.title} — Leonfindel`}
  type={item.type === 'video' ? 'video.other' : 'article'}
  image={item.thumbnail_url ?? undefined}
  jsonLd={structuredDataForItem(item)}
>
  <article class="container">
    <header>
      <p class="code faint">{item.code}</p>
      <h1>{item.title}</h1>
      {subtitle && <p class="muted">{subtitle}</p>}
    </header>

    <div class="player">
      {
        item.type === 'video' && item.embed_url ? (
          <iframe
            src={item.embed_url}
            title={item.title}
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        ) : item.thumbnail_url ? (
          <img src={item.thumbnail_url} alt={item.title} />
        ) : (
          <div class="placeholder">Sin preview disponible</div>
        )
      }
    </div>

    {item.description && <p class="description">{item.description}</p>}

    <dl class="meta">
      {item.location && (<>
        <dt>Locación</dt>
        <dd>{item.location}</dd>
      </>)}
      {item.year && (<>
        <dt>Año</dt>
        <dd>{item.year}</dd>
      </>)}
      {item.duration_sec && (<>
        <dt>Duración</dt>
        <dd>{Math.floor(item.duration_sec / 60)}:{String(item.duration_sec % 60).padStart(2, '0')}</dd>
      </>)}
      {item.source_url && (<>
        <dt>Original</dt>
        <dd><a href={item.source_url} rel="noopener" target="_blank">{item.source}</a></dd>
      </>)}
    </dl>

    {
      tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => (
            <li>{t}</li>
          ))}
        </ul>
      )
    }
  </article>

  <style>
    article {
      max-width: 960px;
      margin-inline: auto;
    }
    .code {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      margin: 0 0 0.5rem;
    }
    h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      margin-bottom: 0.5rem;
    }
    .player {
      aspect-ratio: 16 / 9;
      background: var(--bg-elev);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-block: 2rem;
    }
    .player iframe,
    .player img {
      width: 100%;
      height: 100%;
      border: 0;
    }
    .player img {
      object-fit: cover;
    }
    .placeholder {
      display: grid;
      place-items: center;
      height: 100%;
      color: var(--fg-faint);
    }
    .description {
      max-width: 60ch;
      font-size: 1.05rem;
    }
    .meta {
      display: grid;
      grid-template-columns: max-content 1fr;
      gap: 0.5rem 1.5rem;
      margin-block: 2rem;
      font-size: 0.95rem;
    }
    .meta dt {
      color: var(--fg-muted);
    }
    .meta dd {
      margin: 0;
    }
    .tags {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .tags li {
      font-size: 0.8rem;
      padding: 0.25rem 0.6rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--fg-muted);
    }
  </style>
</Base>
