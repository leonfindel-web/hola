---
import { localizedPath, type Lang } from '../../lib/i18n';
import { GAMES } from '../../lib/games-data';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const copy = {
  en: {
    eyebrow: 'Corte Ferpecto — mini-games',
    title: 'Learn video editing by playing.',
    lead: 'A series of educational mini-games about editing and film production, made by Leonfindel. A side project — not part of the audiovisual catalogue.',
    play: 'Play',
  },
  es: {
    eyebrow: 'Corte Ferpecto — mini-juegos',
    title: 'Aprende edición de video jugando.',
    lead: 'Una serie de mini-juegos educativos sobre técnicas de edición y producción audiovisual, hechos por Leonfindel. Un proyecto aparte — no forma parte del catálogo audiovisual.',
    play: 'Jugar',
  },
}[lang];
---

<section class="container games">
  <header class="games__head">
    <p class="games__eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p class="games__lead muted">{copy.lead}</p>
  </header>

  <div class="games__grid">
    {
      GAMES.map((game) => (
        <a class="chip" href={localizedPath(lang, `/games/${game.slug}`)}>
          <span class="chip__type">{game.code}</span>
          <span class="chip__title">{game.title[lang]}</span>
          <span class="chip__desc">{game.description[lang]}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .games {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .games__head {
    max-width: 40rem;
    margin-bottom: 2.5rem;
  }
  .games__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }
  .games__head h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    line-height: 1.08;
    margin: 0 0 0.85rem;
    text-wrap: balance;
  }
  .games__lead {
    color: var(--color-fg-muted);
    font-size: 1.05rem;
  }
  .games__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
  }
  .chip {
    display: grid;
    gap: 0.5rem;
    padding: 1.15rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    min-height: 9.5rem;
    align-content: space-between;
    transition: border-color var(--dur) var(--ease);
  }
  .chip:hover {
    border-color: var(--color-accent);
  }
  .chip__type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }
  .chip__title {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .chip__desc {
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }
</style>
