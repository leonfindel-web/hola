---
import Hero from '../Hero.astro';
import { t, localizedPath, type Lang } from '../../lib/i18n';
import { getAllPieces, type CatalogPiece } from '../../lib/catalog-data';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);
const workHref = localizedPath(lang, '/work');

// A small curated strip of starred pieces as a teaser into the archive.
const featured: CatalogPiece[] = getAllPieces()
  .filter((p) => p.starred)
  .slice(0, 6);
const totalCount = getAllPieces().length;
---

<Hero lang={lang} />

<section class="featured container">
  <header class="featured__head">
    <h2>{dict.work.title}</h2>
    <a class="featured__link" href={workHref}>{dict.home.enterArchive} →</a>
  </header>

  <ul class="strip">
    {
      featured.map((p) => (
        <li>
          <a class="chip" href={`${workHref}/${p.slug}`}>
            <span class="chip__type">{p.serviceType ?? '—'}</span>
            <span class="chip__title">{p.title}</span>
            {p.code && <span class="chip__code">{p.code}</span>}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="featured__count">
    <span class="featured__count-num">{totalCount.toLocaleString('en-US')}</span>
    {lang === 'es' ? 'piezas catalogadas' : 'catalogued pieces'}
  </p>
</section>

<style>
  .featured {
    padding-block: clamp(3rem, 7vw, 5rem);
  }
  .featured__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .featured__head h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
  .featured__link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: var(--tracking-code);
    color: var(--color-fg-muted);
  }
  .featured__link:hover {
    color: var(--color-accent);
  }
  .strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  .chip {
    display: grid;
    gap: 0.45rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    min-height: 8.5rem;
    align-content: space-between;
    transition: border-color var(--dur) var(--ease);
  }
  .chip:hover {
    border-color: var(--color-accent);
  }
  .chip__type {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }
  .chip__title {
    font-size: 1rem;
    line-height: 1.3;
  }
  .chip__code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-fg-faint);
    letter-spacing: var(--tracking-code);
  }
  .featured__count {
    margin: 2.5rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }
  .featured__count-num {
    color: var(--color-fg);
    font-size: 1.05rem;
  }
</style>
